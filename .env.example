# LINE channel 環境變數。實際值由 /line:configure 寫到 ~/.claude/channels/line/.env。
# 必填
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 選填(預設值)
# LINE_HOST=127.0.0.1
# LINE_PORT=8788
# LINE_MAX_MEDIA_BYTES=20971520

# 直接以 Bun 原生 TLS 對外提供 HTTPS(免反向代理):兩者都設,server 就聽 HTTPS。
# CERT 用「完整鏈」fullchain.pem(leaf + 中繼)、KEY 用 privkey.pem。通常配 LINE_PORT=443、LINE_HOST=0.0.0.0。
# 未設則維持 plain HTTP(由 nginx / Caddy 等反代終結 TLS)。憑證續期須自理(Let's Encrypt 90 天)。
# LINE_TLS_CERT=/etc/letsencrypt/live/bot.example.com/fullchain.pem
# LINE_TLS_KEY=/etc/letsencrypt/live/bot.example.com/privkey.pem

# 已移除的環境變數:LINE_GROUP_REQUIRE_MENTION(群組是否需 @ 才投遞)→ 改為 per-group(access.json 的 groupSettings.requireMention,預設 true)

# 歷史庫與 inbox 媒體自動清理:保留天數,設 > 0 才清(啟動 + 每 24h 清掉超過 N 天的列與檔)。預設 0 = 永久保留。
# LINE_RETENTION_DAYS=0

# 長任務延後(零 Push):設 true 後,任務逾 LINE_INTERIM_MS 未回會先免費回「處理中」,
# 答案延後到使用者下次傳訊息時免費送出(不耗 Push 額度)。預設 false(走 Reply→Push 級聯)。
# LINE_DEFER_LONG_REPLIES=false
# LINE_INTERIM_MS=50000
# LINE_INTERIM_TEXT=處理中,稍後再傳一則訊息跟我要結果即可

# 多對話路由(隔離串味):設 true 後,instructions 指示主 session 把每個對話路由給獨立 teammate。
# 需另設 CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1(啟動 claude 時),否則 spawn teammate 失敗 → bot 壞。
# 軟控制(靠主 session 自律),長跑可靠度未保證。預設 false。
# LINE_TEAMMATE_ROUTING=false
